# ==========================================
# ZAPCLOUD - Variáveis de Ambiente
# ==========================================

# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL (Prisma)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/zapcloud?schema=public"

# JWT
JWT_SECRET=sua_chave_secreta_muito_forte_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=sua_chave_refresh_muito_forte_aqui
JWT_REFRESH_EXPIRES_IN=30d

# Meta / WhatsApp Business API
META_APP_ID=seu_app_id_da_meta
META_APP_SECRET=seu_app_secret_da_meta
META_VERIFY_TOKEN=token_verificacao_webhook_customizado
META_API_VERSION=v19.0
META_BASE_URL=https://graph.facebook.com

# Embedded Signup - OAuth
META_REDIRECT_URI=http://localhost:3000/api/meta/callback

# WhatsApp Business
WABA_ID=seu_waba_id
PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_TOKEN=seu_token_de_acesso_permanente
